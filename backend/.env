# =========================================
# MoodTune AI — Environment Variables
# =========================================

# PostgreSQL Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/moodtune_db

# JWT Secret Key — change in production!
SECRET_KEY=moodtune-super-secret-jwt-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Storage
SONGS_DIR=./songs
COVERS_DIR=./covers
MODEL_PATH=./app/ai/models/emotion_model.h5

# Future Spotify Integration (placeholder)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback
